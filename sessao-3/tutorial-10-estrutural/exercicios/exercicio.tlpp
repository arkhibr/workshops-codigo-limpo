// Demo (executar como User Function U_DemoExercicio18)
User Function DemoExercicio18()
    Local aBoleto    := {}
    Local cStatus    := ""
    Local lCancelado := .F.

    // Codigo original (Passo 1: adicione // ACOPLAMENTO: nas linhas de chamada legada acima)
    ConOut("=== Exercicio 18 — Sem Adapter ===")
    aBoleto := EmitirCobranca(500.0, "2026-08-15", "CLI-200")
    ConOut("Boleto: id=" + cValToChar(aBoleto[1]) + ", status=" + aBoleto[3])
    cStatus := VerificarCobranca(aBoleto[1])
    ConOut("Status: " + cStatus)
    lCancelado := EstornarCobranca(aBoleto[1])
    ConOut("Cancelado: " + IIf(lCancelado, "sim", "nao"))

    // Passo 3 — descomente para verificar o Adapter:
    // ConOut("")
    // ConOut("=== Passo 3 — Adapter ===")
    // Local aBoletoAdapter := AdaptarEmitir(500.0, "2026-08-15", "CLI-200")
