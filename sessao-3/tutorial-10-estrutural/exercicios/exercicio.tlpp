/*
 * EXERCICIO 18 ADVPL/TLPP — Padroes Estruturais: Adapter + Facade
 *
 * PASSOS:
 *
 *   PASSO 1 — IDENTIFICAR (5 min)
 *     Nas 3 funcoes de negocio (EmitirCobranca, VerificarCobranca, EstornarCobranca),
 *     adicione um comentario // ACOPLAMENTO: antes de cada chamada a User Function legada.
 *     Meta: marcar os 3 acoplamentos antes de alterar codigo.
 *
 *   PASSO 2 — MODELO DE DOMINIO (5 min)
 *     Em ADVPL/TLPP nao ha dataclass; represente o Boleto como array posicional:
 *       [1]=nId, [2]=cCodigo, [3]=cStatus, [4]=nValor
 *     Documente a struct num comentario acima de AdaptarEmitir.
 *     (sem alterar mais nada ainda)
 *
 *   PASSO 3 — ADAPTER (10 min)
 *     Crie as funcoes:
 *       Static Function AdaptarEmitir(nValor, cVencimento, cClienteId)
 *       Static Function AdaptarConsultar(nBoletoId)
 *       Static Function AdaptarCancelar(nBoletoId)
 *     Cada funcao chama a User Function *Legado e normaliza os campos.
 *     Verifique: AdaptarEmitir(500.0, "2026-08-15", "CLI-200") retorna array com nId=12345.
 *
 *   PASSO 4 — FACADE (8 min)
 *     Crie:
 *       Static Function ProcessarCobrancaCompleta(nValor, cVencimento, cClienteId)
 *     Que chama AdaptarEmitir + AdaptarConsultar + AdaptarCancelar e retorna
 *     array com resumo: [1]=nBoletoId, [2]=cCodigo, [3]=cStatusFinal, [4]=lCancelado.
 *     Verifique que o caller nao precisa mais conhecer as User Functions legadas.
 */

// ─── API legada (User Functions — nao podem ser alteradas) ───────────────────

User Function GerarBoletoLegado(nValor, cVencimento, cPagador)
    ConOut("  [Legado] gerarBoleto(" + cPagador + ", R$" + cValToChar(nValor) + ")")
    Local aRet := {}
    aAdd(aRet, 12345)                       // [1] nIdBoleto
    aAdd(aRet, "9999.99999 99999.999999")   // [2] cCodigoBarras
    aAdd(aRet, "ATIVO")                     // [3] cStatusBoleto
    aAdd(aRet, nValor)                      // [4] nValorBoleto
Return aRet

User Function ConsultarStatusLegado(nIdBoleto)
    ConOut("  [Legado] consultarStatus(" + cValToChar(nIdBoleto) + ")")
Return "ATIVO"

User Function CancelarBoletoLegado(nIdBoleto, cMotivo)
    ConOut("  [Legado] cancelarBoleto(" + cValToChar(nIdBoleto) + ", " + cMotivo + ")")
Return .T.


// ─── Codigo de negocio — chama legado diretamente (problema) ─────────────────

Static Function EmitirCobranca(nValor, cVencimento, cClienteId)
    Local aRaw := U_GerarBoletoLegado(nValor, cVencimento, cClienteId)  // acoplamento direto
    Local aRet := {}
    aAdd(aRet, aRaw[1])                // [1] nId
    aAdd(aRet, aRaw[2])                // [2] cCodigo
    aAdd(aRet, Lower(aRaw[3]))         // [3] cStatus
    aAdd(aRet, aRaw[4])                // [4] nValor
Return aRet

Static Function VerificarCobranca(nBoletoId)
    Local cStatus := U_ConsultarStatusLegado(nBoletoId)  // acoplamento direto
Return Lower(cStatus)

Static Function EstornarCobranca(nBoletoId)
Return U_CancelarBoletoLegado(nBoletoId, "SOLICITACAO_CLIENTE")  // acoplamento direto


// ─── Passo 2: documente a struct Boleto aqui ──────────────────────────────────
// Struct Boleto (array posicional):
//   [1] nId          -> nIdBoleto do legado
//   [2] cCodigo      -> cCodigoBarras do legado
//   [3] cStatus      -> cStatusBoleto normalizado (Lower)
//   [4] nValor       -> nValorBoleto do legado


