//
//   Function U_TESTE_IMPOSTO()
//       Local aRes
//
//       // PJ, valor alto, poucos itens
//       aRes := CALC_IMPOSTO_PED(8000, "PJ", 2)
//       Assert(aRes[1] == 960.0,  "Imposto PJ alto incorreto")  // 8000 * 0.12
//       Assert(aRes[2] == 0,      "Nao deve haver desconto")
//       Assert(aRes[3] == 8960.0, "Total PJ incorreto")
//
//       // PF, valor baixo
//       aRes := CALC_IMPOSTO_PED(1500, "PF", 1)
//       Assert(aRes[1] == 195.0,  "Imposto PF incorreto") // 1500*0.03 + 150
//       Assert(aRes[3] == 1695.0, "Total PF incorreto")
//
//       ConOut("Todos os testes passaram.")
//   Return
//
// Antes da extração, testar o cálculo exigia conectar ao banco,
// abrir área SC5 e lidar com lock. Agora basta chamar CALC_IMPOSTO_PED.
// ==========================================================================
