User Function ExercicioFrete()
    ConOut( "=== Verificação: Cálculo de Frete ===" )
    ConOut( "" )

    // Usando funções originais (com dívida)
    ConOut( "Frete A, 3kg, 100km: "          + cValToChar( CalcFrete( "A",  3, 100 ) ) )
    ConOut( "Frete A, 15kg, 200km: "         + cValToChar( CalcFrete( "A", 15, 200 ) ) )
    ConOut( "Frete A, 30kg, 300km: "         + cValToChar( CalcFrete( "A", 30, 300 ) ) )
    ConOut( "Frete B, 10kg, 150km: "         + cValToChar( CalcFrete( "B", 10, 150 ) ) )
    ConOut( "Frete C, 25kg, 400km: "         + cValToChar( CalcFrete( "C", 25, 400 ) ) )
    ConOut( "Frete A urgente, 5kg, 100km: "  + cValToChar( CalcFrete( "A",  5, 100, .T. ) ) )
    ConOut( "Estimativa A, 3kg, 100km: "     + cValToChar( Estimar( "A", 3, 100 ) ) )

    // Após implementar, descomente e verifique que os valores batem:
    // ConOut( "" )
