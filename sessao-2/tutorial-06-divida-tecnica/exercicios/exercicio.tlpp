#include "totvs.ch"

// ════════════════════════════════════════════════════════════════════════════════
// CÓDIGO COM DÍVIDA TÉCNICA — identifique e anote as dívidas
// ════════════════════════════════════════════════════════════════════════════════

Static Function CalcFrete( tp, kg, km, urg )
    Local t := 0.0
    If urg == Nil
        urg := .F.
    EndIf
    If tp == "A"
        If kg <= 5
            t := 15.0
        ElseIf kg <= 20
            t := 15.0 + ( kg - 5 ) * 2.5
        Else
            t := 15.0 + ( 20 - 5 ) * 2.5 + ( kg - 20 ) * 1.8
        EndIf
        t += km * 0.12
    ElseIf tp == "B"
        If kg <= 5
            t := 25.0
        ElseIf kg <= 20
            t := 25.0 + ( kg - 5 ) * 3.2
        Else
            t := 25.0 + ( 20 - 5 ) * 3.2 + ( kg - 20 ) * 2.1
        EndIf
        t += km * 0.18
    ElseIf tp == "C"
        If kg <= 5
            t := 40.0
        ElseIf kg <= 20
            t := 40.0 + ( kg - 5 ) * 4.0
        Else
            t := 40.0 + ( 20 - 5 ) * 4.0 + ( kg - 20 ) * 2.8
        EndIf
        t += km * 0.25
    EndIf
    If urg
        t := t * 1.3
    EndIf
Return Round( t, 2 )


Static Function Estimar( tp, kg, km )
    Local t := 0.0
    If tp == "A"
        If kg <= 5
            t := 15.0
        ElseIf kg <= 20
            t := 15.0 + ( kg - 5 ) * 2.5
        Else
            t := 15.0 + ( 20 - 5 ) * 2.5 + ( kg - 20 ) * 1.8
        EndIf
        t += km * 0.12
    ElseIf tp == "B"
        If kg <= 5
            t := 25.0
        ElseIf kg <= 20
            t := 25.0 + ( kg - 5 ) * 3.2
        Else
            t := 25.0 + ( 20 - 5 ) * 3.2 + ( kg - 20 ) * 2.1
        EndIf
        t += km * 0.18
    ElseIf tp == "C"
        If kg <= 5
            t := 40.0
        ElseIf kg <= 20
            t := 40.0 + ( kg - 5 ) * 4.0
        Else
            t := 40.0 + ( 20 - 5 ) * 4.0 + ( kg - 20 ) * 2.8
        EndIf
        t += km * 0.25
    EndIf
Return Round( t, 2 )


