User Function ExercicioFrete()
    ConOut( "=== Verificação: Cálculo de Frete ===" )
    ConOut( "" )

    // Usando funções originais (com dívida)
    ConOut( "Frete A, 3kg, 100km: "          + cValToChar( CalcFrete( "A",  3, 100 ) ) )        // 27
    ConOut( "Frete A, 15kg, 200km: "         + cValToChar( CalcFrete( "A", 15, 200 ) ) )        // 64
    ConOut( "Frete A, 30kg, 300km: "         + cValToChar( CalcFrete( "A", 30, 300 ) ) )        // 106.5
    ConOut( "Frete B, 10kg, 150km: "         + cValToChar( CalcFrete( "B", 10, 150 ) ) )        // 68
    ConOut( "Frete C, 25kg, 400km: "         + cValToChar( CalcFrete( "C", 25, 400 ) ) )        // 214
    ConOut( "Frete A urgente, 5kg, 100km: "  + cValToChar( CalcFrete( "A",  5, 100, .T. ) ) )   // 35.1
    ConOut( "Estimativa A, 3kg, 100km: "     + cValToChar( Estimar( "A", 3, 100 ) ) )           // 27

    // Após o Passo 4, descomente e verifique que os valores batem:
    // ConOut( "" )
    // ConOut( "--- Versão refatorada (Passo 4) ---" )
    // ConOut( "Frete A, 3kg, 100km: "         + cValToChar( CalcularFrete( "A",  3, 100 ) ) )
    // ConOut( "Frete A, 15kg, 200km: "        + cValToChar( CalcularFrete( "A", 15, 200 ) ) )
    // ConOut( "Frete A, 30kg, 300km: "        + cValToChar( CalcularFrete( "A", 30, 300 ) ) )
    // ConOut( "Frete B, 10kg, 150km: "        + cValToChar( CalcularFrete( "B", 10, 150 ) ) )
    // ConOut( "Frete C, 25kg, 400km: "        + cValToChar( CalcularFrete( "C", 25, 400 ) ) )
    // ConOut( "Frete A urgente, 5kg, 100km: " + cValToChar( CalcularFrete( "A",  5, 100, .T. ) ) )
    // ConOut( "Estimativa A, 3kg, 100km: "    + cValToChar( EstimarFrete( "A", 3, 100 ) ) )
Return Nil
