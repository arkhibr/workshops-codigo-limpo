// ════════════════════════════════════════════════════════════════════════════════
// PROBLEMA 1: Codigo com comentarios ruins — remova/reescreva/renomeie
// ════════════════════════════════════════════════════════════════════════════════

// verifica se usuario esta ativo
Function Chk( aU )
    // retorna verdadeiro se st for 1
Return aU["st"] == 1

// calcula o preco com desconto
Function Calc( nP, nD )
    Local nR := 0
    // subtrai o desconto do preco
    nR := nP - nD
    // retorna o resultado
Return nR

Function RegistrarAcesso( cUsuarioId, cTimestamp )
    Local nContador := 0
    // TODO: melhorar isso
    // TODO: adicionar log
    // incrementa o contador
    nContador := 0
    nContador := nContador + 1 // soma 1
    // insere no banco
    // DBInsert("acessos", cUsuarioId, cTimestamp)
    // DBAntigoLog(cUsuarioId)
    // EnviarEmailBoasVindas(cUsuarioId) // nao era necessario
    ConOut( "[LOG] Acesso registrado: " + cUsuarioId + " em " + cTimestamp )
Return nContador

Function CalcularMulta( nDiasAtraso, nValorOriginal )
    // 15/01/2024 - Pedro mudou a multa de 1% para 2%
    // 03/03/2024 - Ana reverteu para 1% a pedido do juridico
    // 10/04/2024 - Carlos subiu para 2% novamente
    Local nTaxaMulta := 0.02
Return nValorOriginal * nTaxaMulta * nDiasAtraso

// ════════════════════════════════════════════════════════════════════════════════
// PROBLEMA 2: Logica nao obvia sem comentario — adicione o comentario correto
// ════════════════════════════════════════════════════════════════════════════════

Function CalcularParcelaFinanciamento( nValorPrincipal, nTaxaMensal, nNumeroParcelas )
    Local nFator   := 0
    Local nParcela := 0
    If nTaxaMensal == 0
        Return Round( nValorPrincipal / nNumeroParcelas, 2 )
    EndIf
    nFator   := ( 1 + nTaxaMensal ) ^ nNumeroParcelas
    nParcela := nValorPrincipal * ( nTaxaMensal * nFator ) / ( nFator - 1 )
Return Round( nParcela, 2 )

