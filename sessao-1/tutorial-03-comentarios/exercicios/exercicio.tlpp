Function Main()
    Local aUsuarioAtivo   := {}
    Local aUsuarioInativo := {}
    Local lResultado      := .F.

    ConOut( "=== Verificacao do Exercicio ===" )
    ConOut( "" )

    // Problema 1
    aUsuarioAtivo             := {}
    aUsuarioAtivo["st"]       := 1
    aUsuarioAtivo["nome"]     := "Maria"

    aUsuarioInativo           := {}
    aUsuarioInativo["st"]     := 0
    aUsuarioInativo["nome"]   := "Joao"

    lResultado := Chk( aUsuarioAtivo )
    ConOut( "Chk (ativo): " + If( lResultado, ".T.", ".F." ) )       // esperado: .T.

    lResultado := Chk( aUsuarioInativo )
    ConOut( "Chk (inativo): " + If( lResultado, ".T.", ".F." ) )     // esperado: .F.

    ConOut( "Calc(100, 15): " + Str( Calc( 100.0, 15.0 ) ) )        // esperado: 85

    RegistrarAcesso( "U001", "2026-04-14 10:00:00" )

    ConOut( "CalcularMulta(5 dias, 200): " + Str( CalcularMulta( 5, 200.0 ) ) ) // esperado: 20

    // Problema 2
    ConOut( "" )
    ConOut( "CalcularParcelaFinanciamento:" )
    ConOut( "  R$10000 / 12x / 1% a.m.: " + Str( CalcularParcelaFinanciamento( 10000.0, 0.01, 12 ) ) )
    ConOut( "  R$5000 / 24x / 0.8% a.m.: " + Str( CalcularParcelaFinanciamento( 5000.0, 0.008, 24 ) ) )
    ConOut( "  R$3000 / 10x / 0% (sem juros): " + Str( CalcularParcelaFinanciamento( 3000.0, 0.0, 10 ) ) )

Return
