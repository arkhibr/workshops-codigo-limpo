    If cMetodo == "CRD"
        nTaxa := 0.025
    EndIf
Return nValor * ( 1 + nTaxa )

// ✅ Bom — código morto removido; histórico fica no controle de versão
#DEFINE TAXA_CREDITO  0.025

Function ProcessarPagamento( nValor, cMetodo )
    Local nTaxa := 0
    If cMetodo == "CRD"
        nTaxa := TAXA_CREDITO
    EndIf
Return nValor * ( 1 + nTaxa )


