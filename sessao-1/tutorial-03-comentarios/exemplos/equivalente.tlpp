// ❌ Ruim — o comentário repete o que o código já diz
Function CalcularTotal_Ruim( nPreco, nQtd )
    // multiplica preço pela quantidade
    Local nTotal := nPreco * nQtd
    // retorna o total
Return nTotal

// ✅ Bom — sem comentário: nome da função é autoexplicativo
Function CalcularTotal( nPreco, nQtd )
    Local nTotal := nPreco * nQtd
Return nTotal


